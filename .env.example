# SignalForge Environment Variables
# Telegram Bot (@SignalForge7bot)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_URL=https://your-app.up.railway.app/telegram-webhook

# Webhook API Key (for POST /webhook auth)
WEBHOOK_API_KEY=your_webhook_api_key_here

# KeeperHub
KEEPERHUB_API_URL=https://api.keeperhub.com
KEEPERHUB_API_KEY=your_keeperhub_api_key_here

# 0G.ai
0G_AI_API_KEY=your_0g_ai_api_key_here

# Redis
REDIS_HOST=your_redis_host
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_TLS=false           # set to 'true' only if your Redis provider requires TLS

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
